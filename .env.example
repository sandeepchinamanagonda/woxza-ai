# Copy this file to .env. Never commit .env or real secrets.

# Docker/PostgreSQL — local values are fine for development; change them for shared environments.
POSTGRES_DB=voxa
POSTGRES_USER=voxa
POSTGRES_PASSWORD=change-this-local-postgres-password
POSTGRES_PORT=5432
API_PORT=8787
WEB_PORT=3456

# Public URL used by Plivo/Twilio to reach the local API. setup.sh replaces this
# with the active ngrok HTTPS URL; do not enter a localhost URL here.
PUBLIC_API_URL=https://replace-me.ngrok-free.app
WEBSITE_URL=http://localhost:3456
CORS_ORIGINS=http://localhost:3456

# Gemini Live — create an API key in Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=replace-with-google-ai-studio-key
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
GEMINI_DEMO_VOICE=Kore

# India / Plivo voice — from the Plivo console: https://console.plivo.com/
PLIVO_AUTH_ID=replace-with-plivo-auth-id
PLIVO_AUTH_TOKEN=replace-with-plivo-auth-token
PLIVO_FROM_NUMBER=+910000000000

# US / Twilio voice — from the Twilio Console: https://console.twilio.com/
# Use TWILIO_AUTH_TOKEN, or a TWILIO_API_KEY_SID plus TWILIO_API_KEY_SECRET.
TWILIO_ACCOUNT_SID=replace-with-twilio-account-sid
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_AUTH_TOKEN=replace-with-twilio-auth-token
TWILIO_FROM_NUMBER=+10000000000

# ngrok — install from https://ngrok.com/download and obtain an authtoken from
# https://dashboard.ngrok.com/get-started/your-authtoken. Optional when ngrok
# has already been configured with `ngrok config add-authtoken`.
NGROK_AUTHTOKEN=
# Optional reserved ngrok domain, for example demo.example.ngrok-free.app.
NGROK_DOMAIN=
# setup.sh searches both the standard 4040 inspector and the previous local 4041 inspector.
NGROK_INSPECTOR_PORTS="4040 4041"

# Frontend — leave blank for Docker/Nginx same-origin API proxy. Set an API URL
# only when running the Vite frontend outside Docker.
VITE_API_BASE_URL=
VITE_DEMO_ADMIN_MODE=false

# Optional local test phone that bypasses public demo rate limits. Use E.164 format.
DEMO_TEST_PHONE=

# Admin lead export — create a long random value locally, for example with `openssl rand -hex 32`.
ADMIN_API_TOKEN=replace-with-a-long-random-admin-token

# Optional Resend follow-up emails — create an API key at https://resend.com/api-keys.
RESEND_API_KEY=
DEMO_EMAIL_FROM="Voxa <demo@example.com>"

# HMAC secret for unsubscribe links — generate with `openssl rand -hex 32`.
UNSUBSCRIBE_SIGNING_SECRET=replace-with-at-least-32-random-characters

# Local-only Node database overrides. Docker Compose supplies PG* automatically;
# use one of these only when running `node backend/src/server.js` directly.
DATABASE_URL=
PGHOST=
PGPORT=5432
PGDATABASE=voxa
PGUSER=voxa
PGPASSWORD=
DB_POOL_SIZE=10
DB_CONNECT_RETRIES=20
REDIS_URL=redis://localhost:6379
PORT=8787

# Legacy Exotel compatibility values. The current public demo routes India via
# Plivo and US numbers via Twilio; these are not required for the current flow.
TELEPHONY_PROVIDER=plivo
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_EXOPHONE=
EXOTEL_APP_ID=
GEMINI_LIVE_BRIDGE_URL=
