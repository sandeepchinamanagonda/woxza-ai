# Frontend/API
VITE_API_BASE_URL=
PUBLIC_API_URL=https://api.example.com
WEBSITE_URL=https://example.com
CORS_ORIGINS=http://localhost:3000
ADMIN_API_TOKEN=replace-with-a-long-random-token

# Existing shared Redis/BullMQ connection
REDIS_URL=redis://localhost:6379

# Plivo outbound calling
TELEPHONY_PROVIDER=exotel
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=

# Exotel outbound calling (create a fresh key; never commit live credentials)
EXOTEL_ACCOUNT_SID=
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_EXOPHONE=
EXOTEL_APP_ID=

# Existing Gemini Live audio WebSocket bridge (wss://...)
GEMINI_LIVE_BRIDGE_URL=

# Demo follow-up email (Resend)
RESEND_API_KEY=
DEMO_EMAIL_FROM=Voxa <demo@example.com>

# HMAC secret for one-click unsubscribe links
UNSUBSCRIBE_SIGNING_SECRET=replace-with-at-least-32-random-characters
