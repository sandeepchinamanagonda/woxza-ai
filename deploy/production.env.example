# Copy this to .env.production on the OCI VM and replace every example value.
# Keep this file on the VM only; it must never be committed.
POSTGRES_DB=voxa
POSTGRES_USER=voxa
POSTGRES_PASSWORD=generate-a-long-random-password
API_PORT=8787
WEB_PORT=127.0.0.1:3456

PUBLIC_API_URL=https://woxza.io
WEBSITE_URL=https://woxza.io
CORS_ORIGINS=https://woxza.io

GEMINI_API_KEY=
PLIVO_AUTH_ID=
PLIVO_AUTH_TOKEN=
PLIVO_FROM_NUMBER=
ADMIN_API_TOKEN=
RESEND_API_KEY=
DEMO_EMAIL_FROM="Woxza <demo@example.com>"
UNSUBSCRIBE_SIGNING_SECRET=generate-at-least-32-random-characters
